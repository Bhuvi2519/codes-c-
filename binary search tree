#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int a[] = {10, 20, 30, 40, 50}, n = 5, choice, key;
    while (true) {
        cout << "\n1<-Search\n2<-Exit\nChoice: ";
        cin >> choice;
        if (choice == 2) break;

        cout << "Enter value: ";
        cin >> key;

        int low = 0, high = n - 1, mid, res = -1;
        while (low <= high) {
            mid = (low + high) / 2;
            if (a[mid] == key) { res = mid; break; }
            (a[mid] < key) ? low = mid + 1 : high = mid - 1;
        }
        (res != -1) ? cout << "Found at index " << res : cout << "Not Found";
    }
    cout << "End of session";
    return 0;
}
